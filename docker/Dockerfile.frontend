ARG NPM_REGISTRY=https://mirrors.tuna.tsinghua.edu.cn/npm/

FROM node:20-bookworm-slim AS deps
ARG NPM_REGISTRY
WORKDIR /app
RUN npm config set registry "${NPM_REGISTRY}"
COPY package.json ./
COPY package-lock.json ./
COPY packages/frontend/package.json packages/frontend/package.json
RUN npm ci --workspace=packages/frontend

FROM node:20-bookworm-slim AS builder
ARG NPM_REGISTRY
WORKDIR /app
RUN npm config set registry "${NPM_REGISTRY}"
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build --workspace=packages/frontend

FROM node:20-bookworm-slim AS runner
ARG NPM_REGISTRY
WORKDIR /app
ENV NODE_ENV=production
RUN npm config set registry "${NPM_REGISTRY}"
COPY --from=builder /app/packages/frontend/.next/standalone ./
COPY --from=builder /app/packages/frontend/.next/static ./packages/frontend/.next/static
COPY --from=builder /app/packages/frontend/public ./packages/frontend/public
COPY --from=builder /app/content ./content
COPY --from=builder /app/docs ./docs
COPY --from=builder /app/README.md ./README.md
COPY --from=builder /app/CONTRIBUTING.md ./CONTRIBUTING.md
COPY --from=builder /app/CODE_OF_CONDUCT.md ./CODE_OF_CONDUCT.md
COPY --from=builder /app/SECURITY.md ./SECURITY.md
COPY --from=builder /app/CHANGELOG.md ./CHANGELOG.md
COPY --from=builder /app/COMMERCIAL_LICENSE.md ./COMMERCIAL_LICENSE.md
COPY --from=builder /app/LICENSE ./LICENSE
COPY --from=builder /app/NOTICE ./NOTICE
EXPOSE 3000

# The standalone frontend runtime also serves the in-app docs center.
CMD ["node", "packages/frontend/server.js"]
