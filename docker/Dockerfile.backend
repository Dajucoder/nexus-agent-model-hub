ARG NPM_REGISTRY=https://mirrors.tuna.tsinghua.edu.cn/npm/
ARG DEBIAN_MIRROR=http://mirrors.tuna.tsinghua.edu.cn

FROM node:20-bookworm-slim AS deps
ARG NPM_REGISTRY
ARG DEBIAN_MIRROR
WORKDIR /app
RUN sed -i "s|http://deb.debian.org|${DEBIAN_MIRROR}|g; s|http://security.debian.org|${DEBIAN_MIRROR}|g" /etc/apt/sources.list.d/debian.sources \
  && apt-get update \
  && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*
RUN npm config set registry "${NPM_REGISTRY}"
COPY package.json ./
COPY package-lock.json ./
COPY packages/backend/package.json packages/backend/package.json
RUN npm ci --workspace=packages/backend

FROM node:20-bookworm-slim AS builder
ARG NPM_REGISTRY
ARG DEBIAN_MIRROR
WORKDIR /app
RUN sed -i "s|http://deb.debian.org|${DEBIAN_MIRROR}|g; s|http://security.debian.org|${DEBIAN_MIRROR}|g" /etc/apt/sources.list.d/debian.sources \
  && apt-get update \
  && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*
RUN npm config set registry "${NPM_REGISTRY}"
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run db:generate --workspace=packages/backend
RUN npm run build --workspace=packages/backend

FROM node:20-bookworm-slim AS runner
ARG NPM_REGISTRY
ARG DEBIAN_MIRROR
WORKDIR /app
ENV NODE_ENV=production
RUN sed -i "s|http://deb.debian.org|${DEBIAN_MIRROR}|g; s|http://security.debian.org|${DEBIAN_MIRROR}|g" /etc/apt/sources.list.d/debian.sources \
  && apt-get update \
  && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*
RUN npm config set registry "${NPM_REGISTRY}"
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/backend/dist ./packages/backend/dist
COPY --from=builder /app/packages/backend/prisma ./packages/backend/prisma
COPY --from=builder /app/packages/backend/package.json ./packages/backend/package.json
COPY --from=builder /app/package-lock.json ./package-lock.json
COPY --from=builder /app/package.json ./package.json
EXPOSE 4000
CMD ["sh", "-c", "cd /app/packages/backend && npx prisma migrate deploy && npx prisma db seed && node dist/src/index.js"]
