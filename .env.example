# Application identity
APP_NAME=Nexus Agent Model Hub
APP_VERSION=0.1.0
NODE_ENV=development

# Public ports and URLs used in local development
APP_PORT=4000
FRONTEND_PORT=3000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL defaults for local Docker Compose or a local service
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
POSTGRES_DB=nexus_agent_model_hub
DATABASE_URL=postgresql://nexus:nexus_secret@localhost:5432/nexus_agent_model_hub

# Redis is currently used for rate limiting and future coordination work
REDIS_URL=redis://localhost:6379

# Replace these before any shared or internet-facing deployment
JWT_SECRET=change-me-to-a-random-string-at-least-64-characters-long-1234567890
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-64-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PROVIDER_CONFIG_SECRET=change-me-before-production-provider-storage
BCRYPT_ROUNDS=12

# Browser access control. Comma-separated origins are supported.
# Example for a split deployment:
# CORS_ORIGIN=http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# Agent runtime controls
AGENT_TIMEOUT_MS=30000
AGENT_MAX_RETRIES=2
AGENT_CONCURRENCY_LIMIT=8
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
AGENT_RATE_LIMIT_WINDOW_MS=60000
AGENT_RATE_LIMIT_MAX=30

# Optional external plugin entry points, comma-separated absolute paths
AGENT_PLUGIN_PATHS=

# Outbound allowlist for the built-in HTTP agent tool
AGENT_HTTP_ALLOWED_HOSTS=api.github.com,httpbin.org

# Frontend runtime configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=Nexus Agent Model Hub
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN
