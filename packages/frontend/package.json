{
  "name": "@nexus-agent-model-hub/frontend",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "next dev -p 3000",
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true }); require('node:fs').rmSync('tsconfig.tsbuildinfo', { force: true })\"",
    "build": "next build",
    "start": "next start -p 3000",
    "prelint": "node ./scripts/prepare-typecheck.mjs",
    "lint": "tsc --noEmit",
    "pretypecheck": "node ./scripts/prepare-typecheck.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('frontend tests are documented in docs and can be added with Playwright later')\""
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4"
  }
}
